<header class="navbar">
    <div class="logo">
        <img src="/img/logo.svg" alt="ParaBula">
        <span>ParaBula</span>
    </div>
    <nav>
        <a href="#">Menu</a>
        <a href="#">Menu</a>
        <a href="#">Menu</a>
        <a href="#">Equipe</a>
    </nav>
    <button class="btn-top">INTERAGIR</button>
</header>

<main class="container">

    <h1>Resultados da Análise</h1>

    <div class="results-layout">

        <!-- COLUNA ESQUERDA -->
        <div class="results-left">

            <div class="patient-context">
                <h3>Contexto do Paciente</h3>
                <div class="patient-info">
                    <span>🗓 65 anos</span>
                    <span class="dot">•</span>
                    <span>⚧ Feminino</span>
                    <span>Não gestante</span>
                </div>
                <div class="patient-comorbidades">
                    <span>🫁 Comorbidades: Diabetes, Hipertensão arterial</span>
                </div>
            </div>

            <div class="summary-box">
                <h3>Resumo</h3>
                <div class="summary-alert high">
                    <span>⚠️</span>
                    <strong>Interação de Alta Severidade Encontrada</strong>
                </div>
                <p>Foram identificadas interações clinicamente relevantes entre os medicamentos informados.</p>
                <div class="severity-counts">
                    <span class="badge-alta">Alta <strong>1</strong></span>
                    <span class="badge-moderada">Moderada <strong>1</strong></span>
                    <span class="badge-baixa">Baixa <strong>1</strong></span>
                </div>
                <p class="summary-hint">Clique em uma interação para ver os detalhes.</p>
            </div>

        </div>

        <!-- COLUNA DIREITA -->
        <div class="results-right">

            <h3>Interações Encontradas</h3>

            <div class="interaction-item high">
                <span class="severity-tag alta">ALTA</span>
                <span class="interaction-name">Claritromicina x Sinvastatina</span>
                <span class="arrow">›</span>
            </div>

            <div class="interaction-item medium">
                <span class="severity-tag moderada">MODERADA</span>
                <span class="interaction-name">Claritromicina x Sinvastatina</span>
                <span class="arrow">›</span>
            </div>

            <div class="interaction-item low">
                <span class="severity-tag baixa">BAIXA</span>
                <span class="interaction-name">Claritromicina x Sinvastatina</span>
                <span class="arrow">›</span>
            </div>

        </div>

    </div>

</main>
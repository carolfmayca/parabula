<header class="navbar">
    <div class="logo">
        <img src="/img/logo.svg" alt="ParaBula">
        <span>ParaBula</span>
    </div>

    <nav>
        <a href="#">Funcionalidades</a>
        <a href="#">Como utilizar?</a>
        <a href="#">Equipe</a>
    </nav>

    <a href="/" class="btn-top">Nova Análise</a>
</header>

<main class="results-page">
    <section class="results-hero">
        <div>
            <h1>Análise de Interações e Riscos</h1>
            <p>Resultado da análise com base nas bulas e no perfil do paciente</p>
        </div>
        <a href="/" class="btn-outline">INTERAGIR</a>
    </section>

    <section class="results-top-grid">
        <article class="summary-card {{severityClass apiResponse.interactions.summary.severity}}">
            <div class="summary-card-head">
                <h2>Interações medicamentosas</h2>
                {{#if apiResponse.interactions.summary.interactions_found}}
                <span class="severity-pill {{severityClass apiResponse.interactions.summary.severity}}">{{severityLabel apiResponse.interactions.summary.severity}}</span>
                {{/if}}
            </div>
            <p>
                {{#if apiResponse.interactions.summary.interactions_found}}
                    {{#if (eq apiResponse.interactions.details.length 1)}}
                    Foi identificada 1 interação medicamentosa relevante para os medicamentos analisados.
                    {{else}}
                    Foram identificadas {{apiResponse.interactions.details.length}} interações medicamentosas relevantes para os medicamentos analisados.
                    {{/if}}
                {{else}}
                Nenhuma interação medicamentosa relevante foi identificada para os medicamentos analisados.
                {{/if}}
            </p>
        </article>

        <article class="summary-card {{riskSeverityClass apiResponse.clinical_risks}}">
            <div class="summary-card-head">
                <h2>Riscos para o paciente</h2>
                <span class="severity-pill {{riskSeverityClass apiResponse.clinical_risks}}">{{riskSeverityLabel apiResponse.clinical_risks}}</span>
            </div>
            <p>
                {{#if apiResponse.clinical_risks.risks_found}}
                Foram identificados {{apiResponse.clinical_risks.items.length}} riscos relacionados ao perfil do paciente.
                {{else}}
                Nenhum risco clínico relevante foi identificado para o perfil informado.
                {{/if}}
            </p>
        </article>
    </section>

    <section class="context-grid">
        <article class="context-card">
            <h3>Perfil do paciente</h3>
            <div class="context-meta">
                <div>
                    <span class="context-label">Idade</span>
                    <strong>{{ptAge patient.age}}</strong>
                </div>
                <div>
                    <span class="context-label">Sexo biológico</span>
                    <strong>{{ptSex patient.biological_sex}}</strong>
                </div>
                <div>
                    <span class="context-label">Gestante</span>
                    <strong>{{ptPregnant patient.is_pregnant}}</strong>
                </div>
                <div>
                    <span class="context-label">Comorbidades</span>
                    <strong>{{ptComorbidities patient.comorbidities}}</strong>
                </div>
            </div>
        </article>

        <article class="context-card">
            <h3>Medicamentos analisados</h3>
            <div class="med-tag-list">
                {{#each drugs}}
                <span class="med-tag">
                    {{capitalizeFirst this.name}}
                    {{#if this.via}} · {{ptVia this.via}}{{/if}}
                </span>
                {{/each}}
            </div>
        </article>
    </section>

    {{#if apiResponse.ignored_drugs.length}}
    <section class="ignored-drugs-alert">
        <h3>Medicamentos não analisados</h3>
        <p>Não foi possível encontrar bula para estes medicamentos, então eles ficaram fora desta análise.</p>
        <div class="med-tag-list">
            {{#each apiResponse.ignored_drugs}}
            <span class="med-tag ignored">{{capitalizeFirst this.drug}}</span>
            {{/each}}
        </div>
    </section>
    {{/if}}

    <section class="details-section">
        <header class="details-header">
            <h3>Interações Medicamentosas</h3>
            {{#if apiResponse.interactions.summary.interactions_found}}
            <span class="severity-pill {{severityClass apiResponse.interactions.summary.severity}}">{{severityLabel apiResponse.interactions.summary.severity}}</span>
            {{/if}}
        </header>
        <p class="details-subtitle">Interações entre os medicamentos que podem alterar o efeito, segurança ou toxicidade.</p>

        {{#if apiResponse.interactions.details.length}}
            {{#each apiResponse.interactions.details}}
            <article class="interaction-row" data-index="{{@index}}">
                <div class="interaction-drugs">
                    <span class="interaction-drug-chip {{severityClass this.severity}}">{{capitalizeFirst this.drugs.[0]}}</span>
                    <span class="interaction-x {{severityClass this.severity}}">x</span>
                    <span class="interaction-drug-chip {{severityClass this.severity}}">{{capitalizeFirst this.drugs.[1]}}</span>
                </div>
                <div class="interaction-desc">
                    <div class="interaction-severity">
                        <span class="severity-dot {{severityClass this.severity}}"></span>
                        <strong>{{severityText this.severity}}</strong>
                    </div>
                    <p>{{../apiResponse.interactions.summary.description}}</p>
                </div>
                <button type="button" class="details-link" data-target="detail-interaction-{{@index}}">Ver detalhes <span class="details-arrow">▾</span></button>
            </article>
            <div class="interaction-detail-panel" id="detail-interaction-{{@index}}">
                <p>{{this.description}}</p>
            </div>
            {{/each}}
        {{else}}
            <div class="empty-state">
                {{apiResponse.interactions.summary.description}}
            </div>
        {{/if}}
    </section>

    <section class="details-section">
        <header class="details-header">
            <h3>Riscos para o paciente</h3>
            <span class="severity-pill {{riskSeverityClass apiResponse.clinical_risks}}">{{riskSeverityLabel apiResponse.clinical_risks}}</span>
        </header>
        <p class="details-subtitle">Riscos clínicos relacionados ao perfil do paciente, como contraindicações, cautelas e advertências.</p>

        {{#if apiResponse.clinical_risks.risks_found}}
            {{#each apiResponse.clinical_risks.items}}
            <article class="risk-row" data-index="{{@index}}">
                <div class="risk-context">
                    <strong>Risco clínico</strong>
                    <span>{{capitalizeFirst this.risk_factor}}</span>
                </div>
                <div class="risk-desc">
                    <div class="interaction-severity">
                        <span class="severity-dot {{severityClass this.severity}}"></span>
                        <strong>{{severityText this.severity}}</strong>
                    </div>
                    <p>{{this.description}}</p>
                </div>
                <div class="risk-actions">
                    <span class="interaction-drug-chip {{severityClass this.severity}}">{{capitalizeFirst this.drug}}</span>
                </div>
            </article>
            {{/each}}
        {{else}}
            <div class="empty-state">
                Nenhum risco clínico relevante encontrado para o perfil do paciente informado.
            </div>
        {{/if}}
    </section>

<script src="/js/results.js"></script>

    <footer class="results-footer-note">
        Este resultado é baseado nas bulas dos medicamentos e não substitui o julgamento clínico. Avalie as informações conforme o contexto do paciente e a prática assistencial.
    </footer>
</main>

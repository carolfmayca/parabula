<header class="navbar">
    <div class="logo">
        <img src="/img/logo.svg" alt="ParaBula">
        <span>ParaBula</span>
    </div>

    <nav>
        <a href="#">Funcionalidades</a>
        <a href="#">Como utilizar?</a>
        <a href="#">Equipe</a>
    </nav>

    <a href="/" class="btn-top">Nova análise</a>
</header>

<main class="results-page">
    <section class="results-hero">
        <div>
            <h1>Análise de Interações e Riscos</h1>
            <p>Resultado da análise com base nas bulas e no perfil do paciente</p>
        </div>
        <a href="/" class="btn-outline">INTERAGIR</a>
    </section>

    <section class="results-top-grid">
        <article class="summary-card {{severityClass apiResponse.summary.severity}}">
            <div class="summary-card-head">
                <h2>Interações medicamentosas</h2>
                <span class="severity-pill {{severityClass apiResponse.summary.severity}}">{{severityLabel apiResponse.summary.severity}}</span>
            </div>
            <p>
                {{#if apiResponse.summary.interactions_found}}
                Foram encontradas {{apiResponse.details.length}} interações relevantes entre os medicamentos analisados.
                {{else}}
                Nenhuma interação relevante foi encontrada entre os medicamentos analisados.
                {{/if}}
            </p>
        </article>

        <article class="summary-card {{severityClass apiResponse.summary.severity}}">
            <div class="summary-card-head">
                <h2>Riscos para o paciente</h2>
                <span class="severity-pill {{severityClass apiResponse.summary.severity}}">{{severityLabel apiResponse.summary.severity}}</span>
            </div>
            <p>
                {{#if patient.comorbidities.length}}
                Foram identificados {{patient.comorbidities.length}} fatores de risco relacionados ao perfil do paciente.
                {{else}}
                Perfil sem comorbidades informadas. Avalie os riscos clínicos conforme contexto assistencial.
                {{/if}}
            </p>
        </article>
    </section>

    <section class="context-grid">
        <article class="context-card">
            <h3>Perfil do paciente</h3>
            <div class="context-meta">
                <div>
                    <span class="context-label">Idade</span>
                    <strong>{{patient.age}} anos</strong>
                </div>
                <div>
                    <span class="context-label">Sexo biológico</span>
                    <strong>{{ptSex patient.biological_sex}}</strong>
                </div>
                <div>
                    <span class="context-label">Gestante</span>
                    <strong>{{#if patient.is_pregnant}}Sim{{else}}Não{{/if}}</strong>
                </div>
                <div>
                    <span class="context-label">Comorbidades</span>
                    <strong>{{#if patient.comorbidities.length}}{{join patient.comorbidities ", "}}{{else}}Não informado{{/if}}</strong>
                </div>
            </div>
        </article>

        <article class="context-card">
            <h3>Medicamentos analisados</h3>
            <div class="med-tag-list">
                {{#each drugs}}
                <span class="med-tag">{{capitalizeFirst this}}</span>
                {{/each}}
            </div>
        </article>
    </section>

    <section class="details-section">
        <header class="details-header">
            <h3>Interações Medicamentosas</h3>
            <span class="severity-pill {{severityClass apiResponse.summary.severity}}">{{severityLabel apiResponse.summary.severity}}</span>
        </header>
        <p class="details-subtitle">Interações entre os medicamentos que podem alterar o efeito, segurança ou toxicidade.</p>

        {{#if apiResponse.details.length}}
            {{#each apiResponse.details}}
            <article class="interaction-row">
                <div class="interaction-drugs">
                    <span class="interaction-drug-chip {{severityClass this.severity}}">{{capitalizeFirst this.drugs.[0]}}</span>
                    <span class="interaction-x {{severityClass this.severity}}">x</span>
                    <span class="interaction-drug-chip {{severityClass this.severity}}">{{capitalizeFirst this.drugs.[1]}}</span>
                </div>
                <div class="interaction-desc">
                    <div class="interaction-severity">
                        <span class="severity-dot {{severityClass this.severity}}"></span>
                        <strong>{{severityText this.severity}}</strong>
                    </div>
                    <p>{{this.description}}</p>
                </div>
                <button type="button" class="details-link">Ver detalhes</button>
            </article>
            {{/each}}
        {{else}}
            <div class="empty-state">
                Nenhuma interação relevante encontrada para os medicamentos selecionados.
            </div>
        {{/if}}
    </section>

    <footer class="results-footer-note">
        Este resultado é baseado nas bulas dos medicamentos e não substitui o julgamento clínico.
        Em caso de dúvidas, consulte um profissional de saúde.
    </footer>
</main>